#include <stdio.h>
#include <stdlib.h>

int main (){
float peso, altura, IMC;
printf ("\nDigite o seu peso em kg: ");
scanf ("%f", &peso);
printf ("\nDigite a sua altura em metros: ");
scanf ("%f", &altura);

IMC = peso/(altura*altura);

printf ("\nSeu IMC e: %.2f", IMC);
return 0;
}
