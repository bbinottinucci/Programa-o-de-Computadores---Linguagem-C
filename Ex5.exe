#include <stdio.h>
#include <stdlib.h>

int main (){
float valor_compra, valor_pago;
int cedulas, troco;

printf ("\Digite o valor da compra: ");
scanf ("%f", &valor_compra);
printf ("\Digite o valor pago pelo cliente: ");
scanf ("%f", &valor_pago);

printf ("\nCompra: R$%.2f", valor_compra);
printf ("\nPagamento: R$%.2f", valor_pago);
troco = valor_pago - valor_compra;
printf ("\nTroco: %.2f", troco);

printf ("\nEM:");

cedulas = troco/100;
printf ("\nR$100,00: %d cedulas", cedulas);

troco = troco%100;
cedulas = troco/50;
printf ("\nR$50,00: %d cedulas", cedulas);

troco = troco%50;
cedulas = troco/20;
printf ("\nR$20,00: %d cedulas", cedulas);

troco = troco%20;
cedulas = troco/10;
printf ("\nR$10,00: %d cedulas", cedulas);

troco = troco%10;
cedulas = troco/5;
printf ("\nR$5,00: %d cedulas", cedulas);

troco = troco%5;
cedulas = troco/1;
printf ("\nR$1,00: %d cedulas", cedulas);


return 0;
}
